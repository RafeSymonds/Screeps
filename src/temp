}

export function requirementParts(spec?: RequirementSpec): number {
    if (spec === undefined) {
        return 0;
    }

    if (typeof spec === "number") {
        return spec;
    }

    return spec.parts ?? 0;
}

export function requirementCreeps(spec?: RequirementSpec): number {
    if (spec === undefined || typeof spec === "number") {
        return 0;
    }

    return spec.creeps ?? 0;
}

