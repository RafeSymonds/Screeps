        if (this.source) {
            this.source.room.memory.numHarvestSpots += this.data.maxSpots;
        }
    }

    public override requirements(): TaskRequirements {
        return {
            mine: {
                parts: 5,
                creeps: Math.max(1, this.data.maxSpots)
            }
